# Relsoft TeamFlow - Environment Variables
# Copy this file to .env and fill in your values from Supabase Dashboard.
#
# Find these at: Supabase Dashboard → Settings → API
#
# WARNING: Use ONLY the "anon" (public) key below.
# NEVER put the service_role key in Flutter code.

SUPABASE_URL=
SUPABASE_ANON_KEY=
